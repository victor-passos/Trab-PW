<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bike Runner Web</title>
    
    <!-- Adicionando Bootstrap via CDN conforme orientado nos slides -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <!-- Barra de Navegação -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">Bike Runner</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/about">Sobre o Jogo</a>
                    </li>
                    <li class="nav-item">
                        <!-- O link para a rota estática do nosso jogo -->
                        <a class="nav-link btn btn-primary text-white ms-3 px-3" href="/game">Jogar Agora</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Contentor Principal onde as Views serão injetadas -->
    <main class="container bg-white p-5 rounded shadow-sm">
        {{{body}}}
    </main>

    <!-- Script do Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
